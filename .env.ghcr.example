BACKEND_IMAGE=ghcr.io/flathack/openclaw-wiki-backend:latest
FRONTEND_IMAGE=ghcr.io/flathack/openclaw-wiki-frontend:latest

POSTGRES_USER=wikiuser
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=flathacks_wiki
DATABASE_URL=postgresql://wikiuser:change-me-postgres-password@postgres:5432/flathacks_wiki?schema=public

JWT_SECRET=change-this-super-secret-jwt-key-in-production-minimum-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe1234
ADMIN_NAME=FlatHacksWiki Admin
ADMIN_RESET_PASSWORD=false

APP_ENV=production
APP_URL=http://localhost:3002
FRONTEND_URL=http://localhost:3002
CORS_ORIGIN=http://localhost:3002

API_PORT=3001
FRONTEND_PORT=3002

KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:26.0
KEYCLOAK_PORT=8081
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-me-keycloak-db-password
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=ChangeMeKeycloak1234
OIDC_REALM=flathackwiki
KEYCLOAK_TEST_ADMIN_EMAIL=admin@local.test
KEYCLOAK_TEST_ADMIN_PASSWORD=ChangeMeKeycloak1234
KEYCLOAK_DEMO_USER_1_USERNAME=
KEYCLOAK_DEMO_USER_1_EMAIL=
KEYCLOAK_DEMO_USER_1_FIRST_NAME=
KEYCLOAK_DEMO_USER_1_LAST_NAME=
KEYCLOAK_DEMO_USER_1_PASSWORD=
KEYCLOAK_DEMO_USER_2_USERNAME=
KEYCLOAK_DEMO_USER_2_EMAIL=
KEYCLOAK_DEMO_USER_2_FIRST_NAME=
KEYCLOAK_DEMO_USER_2_LAST_NAME=
KEYCLOAK_DEMO_USER_2_PASSWORD=

NEXTCLOUD_IMAGE=nextcloud:stable-apache
NEXTCLOUD_CONTAINER_NAME=flathackwiki-nextcloud
NEXTCLOUD_HTTP_PORT=8080
NEXTCLOUD_HTTPS_PORT=8443
NEXTCLOUD_DB_NAME=nextcloud
NEXTCLOUD_DB_USER=nextcloud
NEXTCLOUD_DB_PASSWORD=ChangeMeNextcloudDb1234
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=ChangeMeNextcloud1234
NEXTCLOUD_TRUSTED_DOMAINS=localhost 127.0.0.1
NEXTCLOUD_OVERWRITEHOST=localhost:8443
NEXTCLOUD_OVERWRITEPROTOCOL=https
NEXTCLOUD_INTERNAL_URL=http://nextcloud
NEXTCLOUD_PUBLIC_URL=https://localhost:8443
NEXTCLOUD_CALENDAR_LOOKAHEAD_DAYS=14
NEXTCLOUD_APP_PASSWORD_USER=
NEXTCLOUD_USERNAME=
NEXTCLOUD_APP_PASSWORD=
NEXTCLOUD_OIDC_CLIENT_ID=nextcloud
NEXTCLOUD_OIDC_CLIENT_SECRET=ChangeMeNextcloudOidcClient1234
NEXTCLOUD_PHP_MEMORY_LIMIT=512M
NEXTCLOUD_PHP_UPLOAD_LIMIT=512M

OIDC_ENABLED=true
OIDC_PROVIDER_NAME=Single Sign-On
OIDC_ISSUER=http://keycloak:8080/realms/flathackwiki
OIDC_PUBLIC_ISSUER=http://localhost:8081/realms/flathackwiki
OIDC_CLIENT_ID=flathackwiki
OIDC_CLIENT_SECRET=ChangeMeWikiOidcClient1234
OIDC_REDIRECT_URI=http://localhost:3002/api/v1/auth/oidc/callback
OIDC_DISCOVERY_URI=http://keycloak:8080/realms/flathackwiki/.well-known/openid-configuration
OIDC_SCOPES=openid email profile
OIDC_TOKEN_AUTH_METHOD=client_secret_post
OIDC_DEFAULT_ROLE=VIEWER
OIDC_SUPER_ADMIN_EMAILS=admin@example.com
