BACKEND_IMAGE=ghcr.io/your-github-user-or-org/openclaw-wiki-backend:latest
FRONTEND_IMAGE=ghcr.io/your-github-user-or-org/openclaw-wiki-frontend:latest

POSTGRES_USER=wikiuser
POSTGRES_PASSWORD=wikipass
POSTGRES_DB=flathacks_wiki
POSTGRES_PORT=5432

DATABASE_URL=postgresql://wikiuser:wikipass@postgres:5432/flathacks_wiki?schema=public

JWT_SECRET=change-this-super-secret-jwt-key-in-production-minimum-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe1234
ADMIN_NAME=FlatHacksWiki Admin
ADMIN_RESET_PASSWORD=false

APP_ENV=production
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost
CORS_ORIGIN=http://localhost

API_PORT=3001
FRONTEND_PORT=80

NEXTCLOUD_URL=
NEXTCLOUD_INTERNAL_URL=
NEXTCLOUD_PUBLIC_URL=
NEXTCLOUD_APP_PASSWORD_USER=
NEXTCLOUD_USERNAME=
NEXTCLOUD_APP_PASSWORD=
NEXTCLOUD_CALENDAR_LOOKAHEAD_DAYS=14

OIDC_ENABLED=false
OIDC_PROVIDER_NAME=Zentrales Konto
OIDC_ISSUER=
OIDC_PUBLIC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_SCOPES=openid email profile
OIDC_TOKEN_AUTH_METHOD=client_secret_post
OIDC_DEFAULT_ROLE=VIEWER
