generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id            String     @id @default(uuid())
  email         String     @unique @db.VarChar(255)
  passwordHash  String     @map("password_hash") @db.VarChar(255)
  name          String     @db.VarChar(255)
  status        UserStatus @default(ACTIVE)
  emailVerified Boolean    @default(false)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  // Relations
  profile           UserProfile?
  externalIdentities ExternalIdentity[]
  sessions          UserSession[]
  roleAssignments   RoleAssignment[]
  ownedSpaces       Space[]             @relation("SpaceOwner")
  createdPages      Page[]              @relation("PageCreator")
  createdVersions   PageVersion[]       @relation("VersionCreator")
  comments          Comment[]
  attachments       Attachment[]
  auditLogs         AuditLog[]
  addedSpaces       SpaceMember[]       @relation("MemberAddedBy")
  invites           SpaceInvite[]
  SpaceMember       SpaceMember[]
  PageRestriction   PageRestriction[]
  AttachmentVersion AttachmentVersion[]
  dashboard         UserDashboard?
  bookmarks         Bookmark[]
  commuteProfile    CommuteProfile?
  timeProjects      TimeTrackingProject[]
  timeEntries       TimeEntry[]
  telegramMessages  TelegramChatMessage[]
  amazonPersons     AmazonExpensePerson[]
  amazonOrders      AmazonOrder[]
  amazonImportBatches AmazonOrderImportBatch[]
  amazonSettings    AmazonExpenseSettings?
  amazonSettlementPayments AmazonSettlementPayment[]

  @@map("users")
}

model ExternalIdentity {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  provider  String   @db.VarChar(100)
  subject   String   @db.VarChar(255)
  email     String   @db.VarChar(255)
  username  String?  @db.VarChar(255)
  name      String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, subject])
  @@index([userId])
  @@map("external_identities")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  DELETED
}

model UserProfile {
  userId                 String  @id @map("user_id")
  displayName            String? @map("display_name") @db.VarChar(255)
  avatarUrl              String? @map("avatar_url") @db.VarChar(500)
  timezone               String  @default("UTC") @db.VarChar(50)
  locale                 String  @default("en") @db.VarChar(10)
  dashboardSubtitle      String? @map("dashboard_subtitle") @db.Text
  showDashboardSubtitle  Boolean @default(true) @map("show_dashboard_subtitle")
  uiRadius               Int     @default(28) @map("ui_radius")
  nextcloudUsername      String? @map("nextcloud_username") @db.VarChar(255)
  nextcloudAppPassword   String? @map("nextcloud_app_password") @db.VarChar(255)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  refreshToken String   @map("refresh_token") @db.VarChar(500)
  expiresAt    DateTime @map("expires_at")
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  userAgent    String?  @map("user_agent") @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([refreshToken])
  @@index([userId])
  @@map("user_sessions")
}

// ============================================
// DASHBOARD & PERSONAL WORKSPACE
// ============================================

model UserDashboard {
  id        String          @id @default(uuid())
  userId    String          @unique @map("user_id")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  user    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  widgets UserDashboardWidget[]

  @@map("user_dashboards")
}

model UserDashboardWidget {
  id          String              @id @default(uuid())
  dashboardId String              @map("dashboard_id")
  type        DashboardWidgetType
  title       String?             @db.VarChar(255)
  isVisible   Boolean             @default(true) @map("is_visible")
  isCollapsed Boolean             @default(false) @map("is_collapsed")
  x           Int                 @default(0)
  y           Int                 @default(0)
  width       Int                 @default(4)
  height      Int                 @default(4)
  minWidth    Int                 @default(2) @map("min_width")
  minHeight   Int                 @default(2) @map("min_height")
  maxWidth    Int?                @map("max_width")
  maxHeight   Int?                @map("max_height")
  mobileOrder Int                 @default(0) @map("mobile_order")
  settings    Json?
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  dashboard UserDashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([dashboardId, type])
  @@map("user_dashboard_widgets")
}

enum DashboardWidgetType {
  CLOCK
  WIKI_SEARCH
  WEB_SEARCH
  WEATHER
  CALENDAR
  FAVORITE_SPACES
  NOTES
  STATS
  SPACES
  COMMUTE
  TIME_TRACKER
  BOOKMARKS
  TELEGRAM_CHAT
  AMAZON_EXPENSES
}

model AmazonExpenseSettings {
  userId     String   @id @map("user_id")
  billingDay Int     @default(1) @map("billing_day")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("amazon_expense_settings")
}

model AmazonExpensePerson {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  displayName String   @map("display_name") @db.VarChar(255)
  notes       String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders AmazonOrder[]
  settlementPayments AmazonSettlementPayment[]

  @@index([userId, isActive])
  @@map("amazon_expense_persons")
}

model AmazonOrderImportBatch {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  fileName     String   @map("file_name") @db.VarChar(255)
  fileHash     String   @map("file_hash") @db.VarChar(64)
  importedRows Int      @default(0) @map("imported_rows")
  createdRows  Int      @default(0) @map("created_rows")
  duplicateRows Int     @default(0) @map("duplicate_rows")
  invalidRows  Int      @default(0) @map("invalid_rows")
  errors       Json?
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders AmazonOrder[]

  @@index([userId, createdAt])
  @@unique([userId, fileHash])
  @@map("amazon_order_import_batches")
}

model AmazonOrder {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  personId          String?  @map("person_id")
  importBatchId     String?  @map("import_batch_id")
  orderId           String?  @map("order_id") @db.VarChar(120)
  orderDate         DateTime @map("order_date")
  itemTitle         String   @map("item_title") @db.Text
  quantity          Int      @default(1)
  itemAmount        Decimal  @default(0) @map("item_amount") @db.Decimal(12, 2)
  refundAmount      Decimal  @default(0) @map("refund_amount") @db.Decimal(12, 2)
  totalAmount       Decimal  @default(0) @map("total_amount") @db.Decimal(12, 2)
  currency          String   @default("EUR") @db.VarChar(10)
  paymentInstrument String?  @map("payment_instrument") @db.VarChar(255)
  shipmentDate      DateTime? @map("shipment_date")
  invoiceUrl        String?  @map("invoice_url") @db.Text
  orderUrl          String?  @map("order_url") @db.Text
  rawData           Json?    @map("raw_data")
  duplicateKey      String   @map("duplicate_key") @db.VarChar(500)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  person AmazonExpensePerson? @relation(fields: [personId], references: [id], onDelete: SetNull)
  importBatch AmazonOrderImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  @@unique([userId, duplicateKey])
  @@index([userId, orderDate])
  @@index([userId, personId, orderDate])
  @@index([userId, orderId])
  @@map("amazon_orders")
}

model AmazonSettlementPayment {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  personId       String   @map("person_id")
  periodKey      String   @map("period_key") @db.VarChar(20)
  periodStart    DateTime @map("period_start")
  periodEnd      DateTime @map("period_end")
  amountSnapshot Decimal  @default(0) @map("amount_snapshot") @db.Decimal(12, 2)
  status         SettlementPaymentStatus @default(PAID)
  paidAt         DateTime? @map("paid_at")
  paidNote       String?   @map("paid_note") @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  person AmazonExpensePerson @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([userId, personId, periodKey])
  @@index([userId, periodKey])
  @@map("amazon_settlement_payments")
}

enum SettlementPaymentStatus {
  PAID
}

model TelegramChatMessage {
  id          String                  @id @default(uuid())
  userId      String                  @map("user_id")
  senderRole  TelegramMessageRole     @map("sender_role")
  provider    TelegramMessageProvider @default(LOCAL_PREVIEW)
  content     String                  @db.Text
  chatId      String?                 @map("chat_id") @db.VarChar(100)
  metadata    Json?
  createdAt   DateTime                @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("telegram_chat_messages")
}

enum TelegramMessageRole {
  USER
  BOT
  SYSTEM
}

enum TelegramMessageProvider {
  LOCAL_PREVIEW
  TELEGRAM_PROXY
  OPENCLAW_RELAY
}

model Bookmark {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  parentId    String?  @map("parent_id")
  itemType    BookmarkItemType @default(BOOKMARK) @map("item_type")
  title       String   @db.VarChar(255)
  url         String?  @db.VarChar(2048)
  normalizedUrl String? @map("normalized_url") @db.VarChar(2048)
  domain      String?  @db.VarChar(255)
  description String?  @db.Text
  notes       String?  @db.Text
  category    String?  @db.VarChar(100)
  tags        String[] @default([])
  faviconUrl  String?  @map("favicon_url") @db.Text
  isFavorite  Boolean  @default(false) @map("is_favorite")
  isPinned    Boolean  @default(false) @map("is_pinned")
  isArchived  Boolean  @default(false) @map("is_archived")
  showInToolbar Boolean @default(true) @map("show_in_toolbar")
  linkStatus  BookmarkLinkStatus @default(UNKNOWN) @map("link_status")
  httpStatus  Int?     @map("http_status")
  lastCheckedAt DateTime? @map("last_checked_at")
  lastOpenedAt DateTime? @map("last_opened_at")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent Bookmark? @relation("BookmarkHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children Bookmark[] @relation("BookmarkHierarchy")

  @@index([userId, parentId, sortOrder])
  @@index([userId, isArchived, isFavorite])
  @@index([userId, normalizedUrl])
  @@index([userId, domain])
  @@map("bookmarks")
}

enum BookmarkItemType {
  BOOKMARK
  FOLDER
}

enum BookmarkLinkStatus {
  UNKNOWN
  OK
  BROKEN
  REDIRECTED
}

model CommuteProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique @map("user_id")
  sourceAddress       String   @map("source_address") @db.VarChar(500)
  destinationAddress  String   @map("destination_address") @db.VarChar(500)
  officeDays          String[] @default([]) @map("office_days")
  homeOfficeDays      String[] @default([]) @map("home_office_days")
  outboundLabel       String?  @map("outbound_label") @db.VarChar(100)
  returnLabel         String?  @map("return_label") @db.VarChar(100)
  departureTime       String?  @map("departure_time") @db.VarChar(10)
  returnDepartureTime String?  @map("return_departure_time") @db.VarChar(10)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("commute_profiles")
}

model TimeTrackingProject {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String   @db.VarChar(255)
  description String?  @db.Text
  color       String?  @db.VarChar(20)
  client      String?  @db.VarChar(255)
  category    String?  @db.VarChar(100)
  isArchived  Boolean  @default(false) @map("is_archived")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries TimeEntry[]

  @@index([userId, isArchived])
  @@map("time_tracking_projects")
}

model TimeEntry {
  id               String        @id @default(uuid())
  userId           String        @map("user_id")
  projectId        String        @map("project_id")
  entryType        TimeEntryType @default(TIMER) @map("entry_type")
  startTime        DateTime      @map("start_time")
  endTime          DateTime?     @map("end_time")
  durationMinutes  Int?          @map("duration_minutes")
  note             String?       @db.Text
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  project TimeTrackingProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId, startTime])
  @@index([projectId, startTime])
  @@map("time_entries")
}

enum TimeEntryType {
  TIMER
  MANUAL
}

// ============================================
// RBAC - ROLES & PERMISSIONS
// ============================================

model RoleAssignment {
  id            String    @id @default(uuid())
  roleName      Role      @map("role_name")
  scopeType     ScopeType @default(GLOBAL) @map("scope_type")
  scopeId       String?   @map("scope_id")
  principalType String    @default("user") @map("principal_type")
  principalId   String    @map("principal_id")
  createdAt     DateTime  @default(now()) @map("created_at")

  user User? @relation(fields: [principalId], references: [id], onDelete: Cascade, map: "role_assignment_user")

  @@unique([roleName, scopeType, scopeId, principalType, principalId])
  @@index([principalType, principalId])
  @@map("role_assignments")
}

enum Role {
  SUPER_ADMIN
  SYSTEM_ADMIN
  SPACE_ADMIN
  EDITOR
  AUTHOR
  COMMENTER
  VIEWER
  GUEST
}

enum ScopeType {
  GLOBAL
  SPACE
}

// ============================================
// SPACES
// ============================================

model Space {
  id          String          @id @default(uuid())
  name        String          @db.VarChar(255)
  key         String          @unique @db.VarChar(100)
  description String?         @db.Text
  visibility  SpaceVisibility @default(PRIVATE)
  ownerId     String          @map("owner_id")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  owner   User          @relation("SpaceOwner", fields: [ownerId], references: [id])
  members SpaceMember[]
  pages   Page[]
  invites SpaceInvite[]

  @@map("spaces")
}

enum SpaceVisibility {
  PUBLIC
  PRIVATE
  RESTRICTED
}

model SpaceMember {
  spaceId   String   @map("space_id")
  userId    String   @map("user_id")
  role      Role     @default(VIEWER)
  addedAt   DateTime @default(now()) @map("added_at")
  addedById String?  @map("added_by_id")

  space   Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  addedBy User? @relation("MemberAddedBy", fields: [addedById], references: [id])

  @@id([spaceId, userId])
  @@index([userId])
  @@map("space_members")
}

model SpaceInvite {
  id          String    @id @default(uuid())
  spaceId     String    @map("space_id")
  email       String    @db.VarChar(255)
  role        Role      @default(VIEWER)
  token       String    @unique @db.VarChar(255)
  expiresAt   DateTime  @map("expires_at")
  acceptedAt  DateTime? @map("accepted_at")
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  space     Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  createdBy User  @relation(fields: [createdById], references: [id])

  @@index([email])
  @@index([token])
  @@map("space_invites")
}

// ============================================
// PAGES
// ============================================

model Page {
  id          String     @id @default(uuid())
  spaceId     String     @map("space_id")
  parentId    String?    @map("parent_id")
  title       String     @db.VarChar(500)
  slug        String     @db.VarChar(500)
  content     String?    @db.Text
  status      PageStatus @default(DRAFT)
  position    Int        @default(0)
  createdById String     @map("created_by_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")

  space        Space             @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  parent       Page?             @relation("PageHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children     Page[]            @relation("PageHierarchy")
  creator      User              @relation("PageCreator", fields: [createdById], references: [id])
  versions     PageVersion[]
  comments     Comment[]
  attachments  Attachment[]
  restrictions PageRestriction[]

  @@unique([spaceId, slug])
  @@index([spaceId])
  @@index([parentId])
  @@index([deletedAt])
  @@map("pages")
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  TRASHED
}

model PageVersion {
  id            String   @id @default(uuid())
  pageId        String   @map("page_id")
  versionNumber Int      @map("version_number")
  content       String   @db.Text
  changeNote    String?  @map("change_note") @db.VarChar(500)
  createdById   String   @map("created_by_id")
  createdAt     DateTime @default(now()) @map("created_at")

  page    Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  creator User @relation("VersionCreator", fields: [createdById], references: [id])

  @@unique([pageId, versionNumber])
  @@index([pageId])
  @@map("page_versions")
}

model PageRestriction {
  id              String          @id @default(uuid())
  pageId          String          @map("page_id")
  restrictionType RestrictionType @map("restriction_type")
  principalType   String          @map("principal_type")
  principalId     String          @map("principal_id")
  createdById     String          @map("created_by_id")
  createdAt       DateTime        @default(now()) @map("created_at")

  page    Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  creator User @relation(fields: [createdById], references: [id])

  @@unique([pageId, restrictionType, principalType, principalId])
  @@index([pageId])
  @@map("page_restrictions")
}

enum RestrictionType {
  READ
  EDIT
}

// ============================================
// COMMENTS
// ============================================

model Comment {
  id        String        @id @default(uuid())
  pageId    String        @map("page_id")
  parentId  String?       @map("parent_id")
  userId    String        @map("user_id")
  content   String        @db.Text
  status    CommentStatus @default(VISIBLE)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  deletedAt DateTime?     @map("deleted_at")

  page    Page      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies Comment[] @relation("CommentReplies")

  @@index([pageId])
  @@index([userId])
  @@map("comments")
}

enum CommentStatus {
  VISIBLE
  HIDDEN
  DELETED
}

// ============================================
// ATTACHMENTS
// ============================================

model Attachment {
  id             String    @id @default(uuid())
  pageId         String    @map("page_id")
  uploaderId     String    @map("uploader_id")
  filename       String    @db.VarChar(255)
  originalName   String    @map("original_name") @db.VarChar(255)
  mimeType       String    @map("mime_type") @db.VarChar(100)
  sizeBytes      Int       @map("size_bytes")
  storageKey     String    @map("storage_key") @db.VarChar(500)
  versionCount   Int       @default(1) @map("version_count")
  currentVersion Int       @default(1) @map("current_version")
  createdAt      DateTime  @default(now()) @map("created_at")
  deletedAt      DateTime? @map("deleted_at")

  page     Page                @relation(fields: [pageId], references: [id], onDelete: Cascade)
  uploader User                @relation(fields: [uploaderId], references: [id])
  versions AttachmentVersion[]

  @@index([pageId])
  @@index([uploaderId])
  @@index([deletedAt])
  @@map("attachments")
}

model AttachmentVersion {
  id            String   @id @default(uuid())
  attachmentId  String   @map("attachment_id")
  versionNumber Int      @map("version_number")
  storageKey    String   @map("storage_key") @db.VarChar(500)
  sizeBytes     Int      @map("size_bytes")
  uploadedById  String   @map("uploaded_by_id")
  createdAt     DateTime @default(now()) @map("created_at")

  attachment Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  uploadedBy User       @relation(fields: [uploadedById], references: [id])

  @@unique([attachmentId, versionNumber])
  @@index([attachmentId])
  @@map("attachment_versions")
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id           String   @id @default(uuid())
  userId       String?  @map("user_id")
  action       String   @db.VarChar(100)
  resourceType String   @map("resource_type") @db.VarChar(50)
  resourceId   String?  @map("resource_id")
  metadata     Json?
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  userAgent    String?  @map("user_agent") @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
