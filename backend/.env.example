APP_ENV=development
APP_PORT=3001
APP_URL=http://localhost:3001

DATABASE_URL=postgresql://wikiuser:wikipass@localhost:5432/flathacks_wiki?schema=public

JWT_SECRET=change-this-super-secret-jwt-key-in-production-minimum-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads

CORS_ORIGIN=http://localhost:5173

# Optionale Nextcloud-Kalenderanbindung fuer das Dashboard
# NEXTCLOUD_URL=https://localhost:8443
# Optional getrennt: interne URL fuer Containerzugriff und oeffentliche URL fuer Browser-Links.
# NEXTCLOUD_INTERNAL_URL=http://nextcloud
# NEXTCLOUD_PUBLIC_URL=https://localhost:8443
# Optional: Benutzer, zu dem das globale App-Passwort gehoert. Wenn gesetzt,
# erhalten andere Benutzer eine klare Setup-Meldung statt einer irrefuehrenden 401.
# NEXTCLOUD_APP_PASSWORD_USER=steve
# NEXTCLOUD_USERNAME=steve
# Optional: Wenn leer, wird bei gemeinsamem OIDC-Login der Benutzername aus der externen Identitaet bzw. aus der E-Mail abgeleitet.
# NEXTCLOUD_APP_PASSWORD=replace-with-nextcloud-app-password
# NEXTCLOUD_CALENDAR_LOOKAHEAD_DAYS=14
